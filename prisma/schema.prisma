generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BoundaryApproach {
  operational_control
  financial_control
  equity_share
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  REVIEWER
  APPROVER
  VIEWER
}

enum ScopeKind {
  SCOPE1
  SCOPE2
  SCOPE3
}

enum CalculationMethod {
  ACTIVITY
  SPEND
}

enum ReviewStatus {
  PENDING
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  OVERRIDDEN
}

enum ReviewAction {
  ASSIGNED
  SENT_TO_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  OVERRIDDEN
  COMMENTED
}

enum ImportStatus {
  STARTED
  VALIDATED
  FAILED
  IMPORTED
}

enum MarketingChannel {
  EMAIL
  PHONE
}

enum GdprRequestType {
  ACCESS
  ERASURE
}

enum GdprRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum KsefImportJobStatus {
  PENDING
  IN_PROGRESS
  RETRY
  SUCCEEDED
  FAILED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  memberships   Membership[]
  cookieConsent UserConsent?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model UserConsent {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentVersion     String
  analyticsCookies   Boolean
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Organization {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  regionCode           String?               @default("PL")
  memberships          Membership[]
  carbonProfiles       CarbonProfile[]
  invoices             Invoice[]
  suppliers            Supplier[]
  emissionSources      EmissionSource[]
  emissionFactors      EmissionFactor[]
  emissionCalculations EmissionCalculation[]
  mappingDecisions     MappingDecision[]
  reviewEvents         ReviewEvent[]
  importRuns           FactorImportRun[]
  gdprRequests         GdprRequest[]
  processingRecords    ProcessingRecord[]
  invitations          Invitation[]
  ksefImportJobs       KsefImportJob[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(OWNER)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([userId, organizationId])
}

model CarbonProfile {
  id                        String       @id @default(cuid())
  organizationId            String       @unique
  companyName               String
  reportingYear             Int
  baseYear                  Int
  boundaryApproach          BoundaryApproach
  industry                  String
  ksefTokenMasked           String
  ksefTokenEncrypted        String?
  supportsMarketBased       Boolean      @default(false)
  hasGreenContracts         Boolean      @default(false)
  businessTravelIncluded    Boolean      @default(false)
  employeeCommutingIncluded Boolean      @default(false)
  notes                     String?
  organization              Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
}

model Supplier {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  taxId          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  @@unique([organizationId, name, taxId])
}

model Invoice {
  id             String       @id @default(cuid())
  organizationId String
  supplierId     String?
  externalId     String
  number         String
  issueDate      DateTime
  currency       String
  netValue       Float
  grossValue     Float
  rawPayload     String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier       Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  createdAt      DateTime     @default(now())
  @@unique([organizationId, externalId])
  @@index([organizationId, issueDate])
  @@index([organizationId, createdAt])
}

model EmissionSource {
  id             String       @id @default(cuid())
  organizationId String
  code           String
  name           String
  publisher      String
  sourceUrl      String?
  methodology    String
  version        String
  validFromYear  Int
  validToYear    Int?
  region         String?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  factors        EmissionFactor[]
  @@unique([organizationId, code, version])
}

model EmissionFactor {
  id               String       @id @default(cuid())
  organizationId   String
  emissionSourceId String
  code             String
  name             String
  scope            ScopeKind
  categoryCode     String
  factorValue      Float
  factorUnit       String
  region           String?
  regionPriority   Int          @default(100)
  activityKind     String?
  year             Int
  tags             String?
  metadataJson     Json?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emissionSource   EmissionSource @relation(fields: [emissionSourceId], references: [id], onDelete: Cascade)
  invoiceLines     InvoiceLine[]
  @@unique([organizationId, code, year])
  @@index([organizationId, categoryCode, year])
}

model MappingDecision {
  id                 String       @id @default(cuid())
  organizationId     String
  inputText          String
  normalizedText     String
  scope              ScopeKind
  categoryCode       String
  factorCode         String
  confidence         Float
  ruleMatched        String
  status             ReviewStatus @default(PENDING)
  reviewerComment    String?
  tokensJson         Json
  currentAssigneeId  String?
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceLines       InvoiceLine[]
  reviewEvents       ReviewEvent[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  @@index([organizationId, status, createdAt])
}

model ReviewEvent {
  id                String       @id @default(cuid())
  organizationId    String
  mappingDecisionId String
  actorUserId       String?
  actorRole         Role?
  action            ReviewAction
  fromStatus        ReviewStatus?
  toStatus          ReviewStatus?
  fromCategoryCode  String?
  toCategoryCode    String?
  fromFactorId      String?
  toFactorId        String?
  diffJson          Json
  comment           String?
  createdAt         DateTime     @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mappingDecision   MappingDecision @relation(fields: [mappingDecisionId], references: [id], onDelete: Cascade)
  @@index([organizationId, createdAt])
}

model FactorImportRun {
  id               String       @id @default(cuid())
  organizationId   String
  actorUserId      String?
  sourceCode       String
  sourceUrl        String
  status           ImportStatus
  validationJson   Json
  importedCount    Int          @default(0)
  errorMessage     String?
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId, createdAt])
}

model InvoiceLine {
  id                   String            @id @default(cuid())
  invoiceId            String
  emissionFactorId     String?
  mappingDecisionId    String?
  description          String
  quantity             Float?
  unit                 String?
  netValue             Float
  currency             String
  scope                ScopeKind
  categoryCode         String
  calculationMethod    CalculationMethod
  activityValue        Float?
  activityUnit         String?
  estimated            Boolean           @default(false)
  overrideCategoryCode String?
  overrideFactorId     String?
  invoice              Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  emissionFactor       EmissionFactor?   @relation(fields: [emissionFactorId], references: [id], onDelete: SetNull)
  mappingDecision      MappingDecision?  @relation(fields: [mappingDecisionId], references: [id], onDelete: SetNull)
  @@index([invoiceId, scope, categoryCode])
  @@index([mappingDecisionId])
}

model EmissionCalculation {
  id             String       @id @default(cuid())
  organizationId String
  scope1Kg       Float
  scope2Kg       Float
  scope3Kg       Float
  totalKg        Float
  summaryJson    Json
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  @@index([organizationId, createdAt])
}

model Lead {
  id               String   @id @default(cuid())
  name             String
  email            String
  company          String
  invoices         String
  message          String?
  phone            String?
  acceptPrivacy    Boolean  @default(true)
  marketingEmail   Boolean  @default(false)
  marketingPhone   Boolean  @default(false)
  source           String?
  createdAt        DateTime @default(now())
  consents         LeadMarketingConsent[]
}

model LeadMarketingConsent {
  id               String           @id @default(cuid())
  leadId           String
  channel          MarketingChannel
  consentText      String
  consentVersion   String
  legalBasis       String           @default("art. 6 ust. 1 lit. a RODO")
  formPath         String?
  ipAddress        String?
  userAgent        String?
  grantedAt        DateTime         @default(now())
  lead             Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, channel, grantedAt])
}

model GdprRequest {
  id                String            @id @default(cuid())
  organizationId    String
  requesterUserId   String?
  subjectEmail      String
  type              GdprRequestType
  status            GdprRequestStatus @default(OPEN)
  notes             String?
  processedAt       DateTime?
  processedByUserId String?
  createdAt         DateTime          @default(now())
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@index([subjectEmail])
}

model ProcessingRecord {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  eventType      String
  subjectRef     String?
  legalBasis     String?
  payload        Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([eventType, createdAt])
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  role           Role
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  inviterUserId  String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@index([email, status])
}

model KsefImportJob {
  id                  String             @id @default(cuid())
  organizationId      String
  actorUserId         String?
  referenceNumber     String
  status              KsefImportJobStatus @default(PENDING)
  attemptCount        Int                @default(0)
  maxAttempts         Int                @default(5)
  nextAttemptAt       DateTime?
  lastError           String?
  payloadJson         Json?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, nextAttemptAt, createdAt])
  @@index([organizationId, referenceNumber, createdAt])
}