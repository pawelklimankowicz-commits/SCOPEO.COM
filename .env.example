# Skopiuj do .env i uzupełnij
# Po `docker compose up -d` użyj:
DATABASE_URL="postgresql://scopeo:scopeo@localhost:5433/scopeo"
AUTH_SECRET="wygeneruj-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
RESEND_API_KEY="re_..."
SALES_INBOX_EMAIL="sales@scopeo.com"
LEADS_FROM_EMAIL="Scopeo Leads <leads@scopeo.com>"
REVIEW_WORKFLOW_EMAIL="review@scopeo.com"
DATA_ENCRYPTION_KEY="32-byte-key-base64"
KSEF_TOKEN_ENCRYPTION_KEY="32-byte-key-base64"
# production: https://ksef.mf.gov.pl/api
# test: https://ksef-test.mf.gov.pl/api
KSEF_API_BASE_URL="https://ksef-test.mf.gov.pl/api"
KSEF_WORKER_SECRET="set-worker-secret"
KSEF_FETCH_MAX_ATTEMPTS="4"
KSEF_FETCH_TIMEOUT_MS="15000"
# Opcjonalnie: timeout self-call cron → /api/ksef/jobs/process (domyślnie 55000)
KSEF_CRON_INNER_FETCH_TIMEOUT_MS="55000"
# Opcjonalnie: budżet czasu workera — nie rozpoczyna nowego joba po tym czasie (domyślnie 52000)
KSEF_PROCESS_BUDGET_MS="52000"
CRON_SECRET="generate-with-openssl-rand-base64-32"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
DEFAULT_PRIVACY_ORGANIZATION_ID=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
LEGAL_EMAIL_GENERAL="hello@scopeo.com"
LEGAL_EMAIL_SUPPORT="support@scopeo.com"
LEGAL_EMAIL_PRIVACY="privacy@scopeo.com"
LEGAL_EMAIL_COMPLAINTS="reklamacje@scopeo.com"

# GDPR ERASURE (POST /api/gdpr/requests/[id]/execute): "true" = anonimizacja opisów InvoiceLine przy realizacji usunięcia danych (domyślnie wyłączone, gdy zmienna nie ustawiona).
# GDPR_ERASURE_ANONYMIZE_INVOICES="true"

# Import faktorów UK Gov + EPA (wymaga corocznej aktualizacji po publikacji nowych plików XLSX)
# FACTOR_IMPORT_DATA_YEAR=2025
# FACTOR_IMPORT_UK_DATA_YEAR=2025
# FACTOR_IMPORT_EPA_DATA_YEAR=2025
# FACTOR_IMPORT_UK_GHG_COLUMN="GHG Conversion Factor 2025"
# FACTOR_IMPORT_UK_FLAT_XLSX_URL="https://assets.publishing.service.gov.uk/.../ghg-conversion-factors-2025-flat-format.xlsx"
# FACTOR_IMPORT_EPA_HUB_XLSX_URL="https://www.epa.gov/system/files/.../ghg-emission-factors-hub-2025.xlsx"
# Opcjonalnie: własny zestaw KOBiZE PL (domyślnie data/kobize-pl-factors.json)
# KOBIZE_FACTORS_JSON_PATH="/abs/path/kobize-pl-factors.json"
