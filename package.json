{
  "name": "scopeo-saas",
  "version": "0.9.2",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack -H 127.0.0.1",
    "browser": "open http://127.0.0.1:3000",
    "dev:webpack": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node --import tsx --test tests/integration/emissions-math.test.ts tests/integration/ksef-xml.test.ts tests/integration/payload-security.test.ts tests/integration/kobize-factors.test.ts tests/integration/api-health.test.ts",
    "test:ci": "node --test --experimental-test-coverage tests/unit/*.test.mjs && npm run test:integration",
    "coverage:summary": "node tests/unit/coverage-summary.mjs",
    "report:desktop": "DISABLE_REMOTE_PDF_FONTS=1 node --import tsx scripts/render-ghg-report-preview.tsx",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "node scripts/run-prisma.cjs migrate dev",
    "prisma:migrate:deploy": "node scripts/run-prisma.cjs migrate deploy",
    "prisma:migrate:status": "node scripts/run-prisma.cjs migrate status",
    "db:push": "echo \"Use prisma:migrate or prisma:migrate:deploy instead of db push\" && exit 1",
    "repair": "rm -rf node_modules .next && npm cache clean --force && npm install"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "6.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.48.0",
    "@swc/helpers": "0.5.17",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.2",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "^15.2.4",
    "next-auth": "^4.24.13",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.5",
    "recharts": "^3.8.1",
    "resend": "^6.11.0",
    "stripe": "^22.0.1",
    "xml2js": "^0.6.2",
    "zod": "^3.24.2"
  },
  "overrides": {
    "@swc/helpers": "0.5.17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.15",
    "fast-check": "^3.23.2",
    "prisma": "6.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  }
}
