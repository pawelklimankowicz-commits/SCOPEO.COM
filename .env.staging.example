# Szablon zmiennych dla środowiska STAGING (Vercel: drugi projekt / Preview z osobną bazą).
# Nie commituj wypełnionych sekretów. Skopiuj: cp .env.staging.example .env.staging
# Szczegóły: docs/staging-environment.md
#
# Osobna baza wymagana — inny connection string niż produkcja:
DATABASE_URL="postgresql://user:haslo@host:5432/scopeo_staging?sslmode=require"
#
# Adresy muszą odpowiadać domenie wdrożenia staging (np. https://scopeo-staging.vercel.app):
AUTH_SECRET="inne-min-32-znaki-niz-prod-openssl-rand-base64-32"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://twoj-staging.example.com"
NEXT_PUBLIC_APP_URL="https://twoj-staging.example.com"
#
# Reszta jak .env.example — generuj NOWE klucze (nie kopiuj z produkcji):
# DATA_ENCRYPTION_KEY, KSEF_TOKEN_ENCRYPTION_KEY, CRON_SECRET, HEALTH_CHECK_SECRET, KSEF_WORKER_SECRET
# Stripe: tylko sk_test_ / pk_test_ i ceny testowe; webhook URL = https://twoj-staging.../api/webhooks/stripe
# KSeF: zwykle KSEF_API_BASE_URL="https://ksef-test.mf.gov.pl/api"
#
# Poniżej: treść równoległa do .env.example (uzupełnij wg stagingu).

RESEND_API_KEY="re_..."
SALES_INBOX_EMAIL="sales@scopeo.com"
LEADS_FROM_EMAIL="Scopeo Leads <leads@scopeo.com>"
REVIEW_WORKFLOW_EMAIL="review@scopeo.com"
DATA_ENCRYPTION_KEY="<32 bajty base64, osobne dla staging>"
KSEF_TOKEN_ENCRYPTION_KEY="<osobne dla staging, base64 32B>"
KSEF_API_BASE_URL="https://ksef-test.mf.gov.pl/api"
KSEF_CONTEXT_NIP=""
KSEF_WORKER_SECRET="inny-niz-prod"
KSEF_FETCH_MAX_ATTEMPTS="2"
KSEF_FETCH_TIMEOUT_MS="10000"
INTERNAL_WORKER_URL=""
KSEF_CRON_INNER_FETCH_TIMEOUT_MS="55000"
KSEF_PROCESS_BUDGET_MS="52000"
CRON_SECRET="<losowe, inne niz produkcja>"
HEALTH_CHECK_SECRET="<losowe>"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
DEFAULT_PRIVACY_ORGANIZATION_ID=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
LEGAL_EMAIL_GENERAL="kontakt@twojadomena.pl"
LEGAL_EMAIL_SUPPORT="support@twojadomena.pl"
LEGAL_EMAIL_PRIVACY="privacy@twojadomena.pl"
LEGAL_EMAIL_COMPLAINTS="reklamacje@twojadomena.pl"

# Stripe (test mode na stagingu)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_ID_MIKRO_MONTHLY="price_..."
STRIPE_PRICE_ID_STARTER_MONTHLY="price_..."
STRIPE_PRICE_ID_GROWTH_MONTHLY="price_..."
STRIPE_PRICE_ID_SCALE_MONTHLY="price_..."
STRIPE_PRICE_ID_MIKRO_ANNUAL="price_..."
STRIPE_PRICE_ID_STARTER_ANNUAL="price_..."
STRIPE_PRICE_ID_GROWTH_ANNUAL="price_..."
STRIPE_PRICE_ID_SCALE_ANNUAL="price_..."
STRIPE_TRIAL_DAYS="7"

OPENAI_API_KEY=""
FAQ_ASSISTANT_MODEL="gpt-4o-mini"
FAQ_ASSISTANT_MODEL_FALLBACK=""
FAQ_ASSISTANT_LLM_TIMEOUT_MS=""
FAQ_ASSISTANT_JSON_MODE="1"
