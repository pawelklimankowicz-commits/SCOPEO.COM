{
  "name": "scopeo-saas",
  "version": "0.9.2",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack -H 127.0.0.1",
    "browser": "open http://127.0.0.1:3000",
    "dev:webpack": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test tests/unit/*.test.mjs",
    "test:ci": "node --test --experimental-test-coverage tests/unit/*.test.mjs",
    "coverage:summary": "node tests/unit/coverage-summary.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "db:push": "echo \"Use prisma:migrate or prisma:migrate:deploy instead of db push\" && exit 1",
    "repair": "rm -rf node_modules .next && npm cache clean --force && npm install"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.8.0",
    "@prisma/client": "6.6.0",
    "@sentry/nextjs": "^10.48.0",
    "@swc/helpers": "0.5.17",
    "bcryptjs": "^3.0.2",
    "exceljs": "^4.4.0",
    "next": "^15.2.4",
    "next-auth": "^4.24.13",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.11.0",
    "xml2js": "^0.6.2",
    "zod": "^3.24.2"
  },
  "overrides": {
    "@swc/helpers": "0.5.17"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/xml2js": "^0.4.14",
    "fast-check": "^3.23.2",
    "prisma": "6.6.0",
    "typescript": "^5.8.2"
  }
}
